<DATAFILE>

[FILEINFO]
file='../../data/applicationFiles/antibodyArm1.txt'
delimiter = comma
header={id, visit, time, yAb, init}

[CONTENT]
id = {use=identifier}
time = {use=time}
yAb = {use=observation, type=continuous}
init = {use=regressor}

[SETTINGS]
dataType = {'yAb'=plasma}

<MODEL>

[INDIVIDUAL]
input = {delta_AB_pop, delta_L_pop, delta_S_pop, omega_delta_S, phi_L_pop, omega_phi_L, phi_S_pop, omega_phi_S}

DEFINITION:
delta_AB = {distribution=logNormal, typical=delta_AB_pop, no-variability}
delta_L = {distribution=logNormal, typical=delta_L_pop, no-variability}
delta_S = {distribution=logNormal, typical=delta_S_pop, sd=omega_delta_S}
phi_L = {distribution=logNormal, typical=phi_L_pop, sd=omega_phi_L}
phi_S = {distribution=logNormal, typical=phi_S_pop, sd=omega_phi_S}

[LONGITUDINAL]
input = {a}

file = '../../data/modelFiles/PasinReg.txt'

DEFINITION:
yAb = {distribution=normal, prediction=tAB, errorModel=constant(a)}

<FIT>
data = 'yAb'
model = yAb

<PARAMETER>
a = {value=0.1192722, method=MLE}
delta_AB_pop = {value=0.03, method=FIXED}
delta_L_pop = {value=0.000316, method=FIXED}
delta_S_pop = {value=0.231, method=MLE}
omega_delta_S = {value=0.8849113, method=MLE}
omega_phi_L = {value=0.8457451, method=MLE}
omega_phi_S = {value=0.924304, method=MLE}
phi_L_pop = {value=14.524543, method=MLE}
phi_S_pop = {value=590.3023100000003, method=MLE}

<MONOLIX>

[TASKS]
populationParameters()
individualParameters(method = {conditionalMean, conditionalMode })
fim(method = StochasticApproximation)
logLikelihood(run = false,method = ImportanceSampling)
plotResult(method = {indfits, parameterdistribution, covariancemodeldiagnosis, covariatemodeldiagnosis, obspred, vpc, residualsscatter, residualsdistribution, randomeffects, saemresults })

[SETTINGS]
GLOBAL:
exportpath = '../'

